{
  "name": "canoe-capl-support",
  "displayName": "CANoe CAPL Support",
  "description": "CAPL language support for VSCode with syntax highlighting, hover docs, code completion, jump to definition, find references, and error analysis",
  "version": "1.0.1",
  "publisher": "canoe-capl",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -p ./ -w",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "languages": [
      {
        "id": "capl",
        "aliases": [
          "CAPL",
          "capl"
        ],
        "extensions": [
          ".capl",
          ".can",
          ".cin"
        ],
        "filenamePatterns": [
          "**/*.capl",
          "**/*.can",
          "**/*.cin"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "capl",
        "scopeName": "source.capl",
        "path": "./syntaxes/capl.tmLanguage.json"
      }
    ],
    "configuration": "./language-configuration.json"
  },
  "activationEvents": [
    "onLanguage:capl"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.9.0",
    "typescript": "^6.0.2"
  }
}
