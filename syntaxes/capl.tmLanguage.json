{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CAPL",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#userfunctions" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "userfunctions": {
      "patterns": [
        { "name": "entity.name.function", "match": "^(dword|word|byte|int|long|float|double|char|void)\\s+\\w+\\s*\\(" },
        { "name": "entity.name.function", "match": "^on\\s+\\w+\\s*\\(" }
      ]
    },
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash", "match": "//.*" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double", "begin": "\"", "end": "\"" },
        { "name": "string.quoted.single", "begin": "'", "end": "'" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword", "match": "\\bon\\b" },
        { "name": "keyword", "match": "\\bif\\b" },
        { "name": "keyword", "match": "\\belse\\b" },
        { "name": "keyword", "match": "\\bwhile\\b" },
        { "name": "keyword", "match": "\\bfor\\b" },
        { "name": "keyword", "match": "\\bswitch\\b" },
        { "name": "keyword", "match": "\\bcase\\b" },
        { "name": "keyword", "match": "\\bdefault\\b" },
        { "name": "keyword", "match": "\\breturn\\b" },
        { "name": "keyword", "match": "\\bbreak\\b" },
        { "name": "keyword", "match": "\\bcontinue\\b" },
        { "name": "keyword", "match": "\\bdo\\b" },
        { "name": "keyword", "match": "\\bgoto\\b" },
        { "name": "keyword", "match": "\\bconst\\b" },
        { "name": "keyword", "match": "\\bstatic\\b" },
        { "name": "keyword", "match": "\\bextern\\b" },
        { "name": "keyword", "match": "\\bvolatile\\b" },
        { "name": "keyword", "match": "\\bvoid\\b" },
        { "name": "keyword", "match": "\\benum\\b" },
        { "name": "keyword", "match": "\\bstruct\\b" },
        { "name": "keyword", "match": "\\binclude\\b" },
        { "name": "keyword", "match": "\\bdefine\\b" },
        { "name": "keyword", "match": "\\bifdef\\b" },
        { "name": "keyword", "match": "\\bifndef\\b" },
        { "name": "keyword", "match": "\\bendif\\b" },
        { "name": "keyword", "match": "(?<!@)\\bthis(?=\\b|\\s|\\.)" }
      ]
    },
"functions": {
      "patterns": [
        { "name": "entity.name.function.user", "match": "^(void|int|long|float|double|char|byte|word|dword|qword|boolean)\\s+\\w+\\s*\\(" },
        { "name": "entity.name.function.user", "match": "^on\\s+\\w+\\s*\\(" },
        { "name": "support.function", "match": "\\bwrite\\b|\\bWRITE\\b" },
        { "name": "support.function", "match": "\\bwriteLineEx\\b|\\bWRITELINEEX\\b" },
        { "name": "support.function", "match": "\\bwriteDbgLvlPrefix\\b|\\bWRITEDBGLEVELPREFIX\\b" },
        { "name": "support.function", "match": "\\bsetWriteDbgLevel\\b|\\bSETWRITEDBGLEVEL\\b" },
        { "name": "support.function", "match": "\\boutput\\b|\\bOUTPUT\\b" },
        { "name": "support.function", "match": "\\bputValue\\b|\\bPUTVALUE\\b" },
        { "name": "support.function", "match": "\\bgetValue\\b|\\bGETVALUE\\b" },
        { "name": "support.function", "match": "\\bsetSignal\\b|\\bSETSIGNAL\\b" },
        { "name": "support.function", "match": "\\bgetSignal\\b|\\bGETSIGNAL\\b" },
        { "name": "support.function", "match": "\\bsetTimer\\b|\\bSETTIMER\\b" },
        { "name": "support.function", "match": "\\bsetTimerCyclic\\b|\\bSETTIMERCYCLIC\\b" },
        { "name": "support.function", "match": "\\bcancelTimer\\b|\\bCANCELTIMER\\b" },
        { "name": "support.function", "match": "\b_max\\b|\b_MAX\\b" },
        { "name": "support.function", "match": "\b_min\\b|\b_MIN\\b" },
        { "name": "support.function", "match": "\b_round\\b|\b_ROUND\\b" },
        { "name": "support.function", "match": "\b_abs\\b|\b_ABS\\b" },
        { "name": "support.function", "match": "\\bmemcpy\\b|\\bMEMCPY\\b" },
        { "name": "support.function", "match": "\\bmemset\\b|\\bMEMSET\\b" },
        { "name": "support.function", "match": "\\bstrlen\\b|\\bSTRLEN\\b" },
        { "name": "support.function", "match": "\\bstrcpy\\b|\\bSTRCPY\\b" },
        { "name": "support.function", "match": "\\bsprintf\\b|\\bSPRINTF\\b" },
        { "name": "support.function", "match": "\\bTestStepPass\\b|\\bTESTSTEPPASS\\b" },
        { "name": "support.function", "match": "\\bTestStepFail\\b|\\bTESTSTEPFAIL\\b" },
        { "name": "support.function", "match": "\\bsysvarInt\\b|\\bSYSVARINT\\b" },
        { "name": "support.function", "match": "\\bsysvarFloat\\b|\\bSYSVARFLOAT\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type", "match": "\\bbyte\\b|\\bBYTE\\b" },
        { "name": "storage.type", "match": "\\bword\\b|\\bWORD\\b" },
        { "name": "storage.type", "match": "\\bdword\\b|\\bDWORD\\b" },
        { "name": "storage.type", "match": "\\bqword\\b|\\bQWORD\\b" },
        { "name": "storage.type", "match": "\\bint\\b|\\bINT\\b" },
        { "name": "storage.type", "match": "\\blong\\b|\\bLONG\\b" },
        { "name": "storage.type", "match": "\\bint64\\b|\\bINT64\\b" },
        { "name": "storage.type", "match": "\\bfloat\\b|\\bFLOAT\\b" },
        { "name": "storage.type", "match": "\\bdouble\\b|\\bDOUBLE\\b" },
        { "name": "storage.type", "match": "\\bchar\\b|\\bCHAR\\b" },
        { "name": "storage.type", "match": "\\bboolean\\b|\\bBOOLEAN\\b" },
        { "name": "storage.type", "match": "\\btimer\\b|\\bTIMER\\b" },
        { "name": "storage.type", "match": "\\bmsTimer\\b|\\bMSTIMER\\b|\\bmstimer\\b|\\bMSTIMER\\b" },
        { "name": "storage.type", "match": "\\bmessage\\b|\\bMESSAGE\\b" },
        { "name": "storage.type", "match": "\\bsignal\\b|\\bSIGNAL\\b" },
        { "name": "storage.type", "match": "\\benvvar\\b|\\bENVVAR\\b" },
        { "name": "storage.type", "match": "\\bpdu\\b|\\bPDU\\b" },
        { "name": "storage.type", "match": "\\bsysvar\\b|\\bSYSVAR\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric", "match": "\\b0x[0-9A-Fa-f]+\\b|\\b[0-9]+\\.?[0-9]*([eE][-+]?[0-9]+)?" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator", "match": "[+\\-*/%=<>!&|^~?:]+" }
      ]
    }
  },
  "scopeName": "source.capl"
}