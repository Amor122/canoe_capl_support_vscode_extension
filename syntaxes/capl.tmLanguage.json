{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CAPL",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash", "match": "//.*" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double", "begin": "\"", "end": "\"" },
        { "name": "string.quoted.single", "begin": "'", "end": "'" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword", "match": "\\bif\\b" },
        { "name": "keyword", "match": "\\belse\\b" },
        { "name": "keyword", "match": "\\bwhile\\b" },
        { "name": "keyword", "match": "\\bfor\\b" },
        { "name": "keyword", "match": "\\bswitch\\b" },
        { "name": "keyword", "match": "\\bcase\\b" },
        { "name": "keyword", "match": "\\bdefault\\b" },
        { "name": "keyword", "match": "\\breturn\\b" },
        { "name": "keyword", "match": "\\bbreak\\b" },
        { "name": "keyword", "match": "\\bcontinue\\b" },
        { "name": "keyword", "match": "\\bdo\\b" },
        { "name": "keyword", "match": "\\bgoto\\b" },
        { "name": "keyword", "match": "\\bconst\\b" },
        { "name": "keyword", "match": "\\bstatic\\b" },
        { "name": "keyword", "match": "\\bextern\\b" },
        { "name": "keyword", "match": "\\bvolatile\\b" },
        { "name": "keyword", "match": "\\bvoid\\b" },
        { "name": "keyword", "match": "\\benum\\b" },
        { "name": "keyword", "match": "\\bstruct\\b" },
        { "name": "keyword", "match": "\\binclude\\b" },
        { "name": "keyword", "match": "\\bdefine\\b" },
        { "name": "keyword", "match": "\\bifdef\\b" },
        { "name": "keyword", "match": "\\bifndef\\b" },
        { "name": "keyword", "match": "\\bendif\\b" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "support.function", "match": "\\bwrite\\b" },
        { "name": "support.function", "match": "\\bwriteLineEx\\b" },
        { "name": "support.function", "match": "\\bwriteDbgLvlPrefix\\b" },
        { "name": "support.function", "match": "\\bsetWriteDbgLevel\\b" },
        { "name": "support.function", "match": "\\boutput\\b" },
        { "name": "support.function", "match": "\\belnl\\b" },
        { "name": "support.function", "match": "\\belprintf\\b" },
        { "name": "support.function", "match": "\\bputValue\\b" },
        { "name": "support.function", "match": "\\bgetValue\\b" },
        { "name": "support.function", "match": "\\bsetSignal\\b" },
        { "name": "support.function", "match": "\\bgetSignal\\b" },
        { "name": "support.function", "match": "\\bsetTimer\\b" },
        { "name": "support.function", "match": "\\bsetTimerCyclic\\b" },
        { "name": "support.function", "match": "\\bsetTimerSync\\b" },
        { "name": "support.function", "match": "\\bcancelTimer\\b" },
        { "name": "support.function", "match": "\\belapsed\\b" },
        { "name": "support.function", "match": "\\bisTimerActive\\b" },
        { "name": "support.function", "match": "\\b_max\\b" },
        { "name": "support.function", "match": "\\b_min\\b" },
        { "name": "support.function", "match": "\\b_round\\b" },
        { "name": "support.function", "match": "\\b_pow\\b" },
        { "name": "support.function", "match": "\\b_sqrt\\b" },
        { "name": "support.function", "match": "\\b_abs\\b" },
        { "name": "support.function", "match": "\\b_sign\\b" },
        { "name": "support.function", "match": "\\bsqrt\\b" },
        { "name": "support.function", "match": "\\babs\\b" },
        { "name": "support.function", "match": "\\bsin\\b|\\bcos\\b|\\btan\\b" },
        { "name": "support.function", "match": "\\bmemcpy\\b" },
        { "name": "support.function", "match": "\\bmemset\\b" },
        { "name": "support.function", "match": "\\bmemcmp\\b" },
        { "name": "support.function", "match": "\\bmemmove\\b" },
        { "name": "support.function", "match": "\\bstrlen\\b" },
        { "name": "support.function", "match": "\\bstrcpy\\b" },
        { "name": "support.function", "match": "\\bstrcat\\b" },
        { "name": "support.function", "match": "\\bstrcmp\\b" },
        { "name": "support.function", "match": "\\bsprintf\\b" },
        { "name": "support.function", "match": "\\bsscanf\\b" },
        { "name": "support.function", "match": "\\batoi\\b|\\batof\\b" },
        { "name": "support.function", "match": "\\bTestStepPass\\b" },
        { "name": "support.function", "match": "\\bTestStepFail\\b" },
        { "name": "support.function", "match": "\\bTestStatus\\b" },
        { "name": "support.function", "match": "\\bsysvarInt\\b" },
        { "name": "support.function", "match": "\\bsysvarFloat\\b" },
        { "name": "support.function", "match": "\\bsysvarString\\b" },
        { "name": "support.function", "match": "\\bsysGetVariableLong\\b" },
        { "name": "support.function", "match": "\\bsysSetVariableLong\\b" },
        { "name": "support.function", "match": "\\bILSetOperationMode\\b" },
        { "name": "support.function", "match": "\\bILCanTxOff\\b" },
        { "name": "support.function", "match": "\\bILCanTxOn\\b" },
        { "name": "support.function", "match": "\\blin_wakeup\\b" },
        { "name": "support.function", "match": "\\blin_gotosleep\\b" },
        { "name": "support.function", "match": "\\blinReset\\b" },
        { "name": "support.function", "match": "\\blinInit\\b" },
        { "name": "support.function", "match": "\\bcanReset\\b" },
        { "name": "support.function", "match": "\\bcanInit\\b" },
        { "name": "support.function", "match": "\\bcanOffline\\b" },
        { "name": "support.function", "match": "\\bcanOnline\\b" },
        { "name": "support.function", "match": "\\bxcpConnect\\b" },
        { "name": "support.function", "match": "\\bxcpDisconnect\\b" },
        { "name": "support.function", "match": "\\bxcpUpload\\b" },
        { "name": "support.function", "match": "\\bxcpDownload\\b" },
        { "name": "support.function", "match": "\\bdiagRequest\\b" },
        { "name": "support.function", "match": "\\bdiagSendRequest\\b" },
        { "name": "support.function", "match": "\\bdiagGetLastResponse\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type", "match": "\\bbyte\\b" },
        { "name": "storage.type", "match": "\\bword\\b" },
        { "name": "storage.type", "match": "\\bdword\\b" },
        { "name": "storage.type", "match": "\\bqword\\b" },
        { "name": "storage.type", "match": "\\bint\\b" },
        { "name": "storage.type", "match": "\\blong\\b" },
        { "name": "storage.type", "match": "\\bint64\\b" },
        { "name": "storage.type", "match": "\\bfloat\\b" },
        { "name": "storage.type", "match": "\\bdouble\\b" },
        { "name": "storage.type", "match": "\\bchar\\b" },
        { "name": "storage.type", "match": "\\bboolean\\b" },
        { "name": "storage.type", "match": "\\btimer\\b" },
        { "name": "storage.type", "match": "\\bTimer\\b" },
        { "name": "storage.type", "match": "\\bmsTimer\\b" },
        { "name": "storage.type", "match": "\\bmstimer\\b" },
        { "name": "storage.type", "match": "\\bmessage\\b" },
        { "name": "storage.type", "match": "\\bsignal\\b" },
        { "name": "storage.type", "match": "\\benvvar\\b" },
        { "name": "storage.type", "match": "\\bpdu\\b" },
        { "name": "storage.type", "match": "\\bsysvar\\b" },
        { "name": "storage.type", "match": "\\benum\\b" },
        { "name": "storage.type", "match": "\\bstruct\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric", "match": "\\b0x[0-9A-Fa-f]+\\b|\\b[0-9]+\\.?[0-9]*([eE][-+]?[0-9]+)?" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator", "match": "[+\\-*/%=<>!&|^~?:]+" }
      ]
    }
  },
  "scopeName": "source.capl"
}