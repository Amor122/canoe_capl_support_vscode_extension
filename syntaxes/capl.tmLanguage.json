{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CAPL",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.capl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.capl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.capl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.escape.capl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.capl",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.capl",
          "match": "\\b(if|else|switch|case|default|while|do|for|break|continue|return|goto)\\b"
        },
        {
          "name": "keyword.control.capl",
          "match": "\\bon\\b"
        },
        {
          "name": "keyword.control.capl",
          "match": "\\bon\\w+\\b"
        },
        {
          "name": "storage.type.capl",
          "match": "\\b(const|volatile|extern|static|void|int|long|float|double|char|byte|word|dword|int64|qword|boolean|enumerates|struct|array)\\b"
        },
        {
          "name": "storage.type.capl",
          "match": "\\b(message|signal|timer|envvar|msglist|signallist|sysvar|node)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.capl",
          "match": "\\b(write|writeLineEx|writeDbgLvlPrefix|setWriteDbgLevel|output|elnl|elprintf|elprintfex)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(setTimer|setTimerCyclic|setTimerSync|cancelTimer|mstimer)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(putValue|getValue|setSignal|getSignal|setWrite|getWrite)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(_max|_min|_round|_pow|_sqrt|_abs|_sign)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(sqrt|abs|sin|cos|tan|asin|acos|atan|atan2|log|log10|exp|pow|floor|ceil|round)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(strlen|strcpy|strcat|strcmp|strncmp|sprintf|sscanf|atoi|atof|atol|tolower|toupper|substr|strstr)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(memset|memcpy|memcpy_off|memcmp|memmove)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(filemap|fileclose|fileread|filewrite|filegetc|fileputc|filesetpos|filegetpos)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(logOpen|logClose|logReset|logWrite)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(openPanel|closePanel|enableControl|SetControlProperty|SetControlVisibility)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(TestStepPass|TestStepFail|TestStatus|testWaitForSignalMatch|testWaitForSignalInRange|testWaitForDiagResponse)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(ILSetOperationMode|ILCanTxOff|ILCanTxOn|ILLoad|ILUnload)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(J1939ILSetSignal|J1939ILGetAddress|J1939ILSetMsgEvent|J1939ILSetAddress)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(sysGetVariableLong|sysSetVariableLong|sysGetVariableData|sysSetVariableData)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(diagRequest|diagResponse|diagSendRequest|diagGetLastResponse|diagIsFreeBusy)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(canReset|canInit|canOffline|canOnline|canSetBtr|canSetFilt|canSetMsgBuf)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(linReset|linInit|linSetup|linSendHead|linSendMsg|linGetResponse)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(xcpConnect|xcpDisconnect|xcpUpload|xcpDownload|xcpGetCalPage|xcpSetCalPage)\\b"
        },
        {
          "name": "support.function.capl",
          "match": "\\b(ethernetPacket|OnTcpReceive|OnUdpReceive|IP_Endpoint)\\b"
        }
      ]
    },
    "types": {
      "patterns": []
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.capl",
          "match": "\\b(0x[0-9A-Fa-f]+|[0-9]+\\.?[0-9]*)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.capl",
          "match": "(\\+\\+|\\-\\-|==|!=|<=|>=|&&|\\|\\||<<|>>|\\+=|-=|\\*=|/=|%=|&=|\\^=|<<=|>>=)"
        }
      ]
    }
  },
  "scopeName": "source.capl"
}
